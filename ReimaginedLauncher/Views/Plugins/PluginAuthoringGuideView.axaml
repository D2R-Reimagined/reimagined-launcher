<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ReimaginedLauncher.Views.Plugins.PluginAuthoringGuideView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="18">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Classes="view-title"
                               Text="How To Write a Plugin" />
                    <TextBlock Classes="muted"
                               Text="Use this guide to package a launcher plugin, declare parameters, and write supported JSON operations." />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button x:Name="OpenWikiButton"
                            Content="Open Full Wiki Guide"
                            Click="OnOpenWikiClicked" />
                    <Button Content="Back to Plugins"
                            Click="OnBackToPluginsClicked" />
                </StackPanel>
            </Grid>

            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Classes="section-title"
                               Text="Full Documentation" />
                    <TextBlock Text="The complete, up-to-date plugin authoring guide — including a per-file identification table and worked examples — lives on the project wiki. Click &quot;Open Full Wiki Guide&quot; above to open it in your browser."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Classes="section-title"
                               Text="What a Plugin Is" />
                    <TextBlock Text="A plugin is a zip archive that contains a plugininfo.json file plus one or more plugin JSON files." TextWrapping="Wrap" />
                    <TextBlock Classes="muted"
                               Text="When a plugin is enabled, the launcher reads each listed JSON file and applies its operations before launch." TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="section-title"
                               Text="Required Folder Layout" />
                    <TextBlock Text="The archive can contain folders, but it must include exactly one plugininfo.json." TextWrapping="Wrap" />
                    <TextBox x:Name="FolderLayoutTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             Classes="code-editor"
                             MinHeight="92" />
                </StackPanel>
            </Border>

            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="section-title"
                               Text="plugininfo.json" />
                    <TextBlock Text="plugininfo.json must include name, version, modVersion (in #.#.# format), and at least one plugin JSON file path. author and description are optional." TextWrapping="Wrap" />
                    <TextBlock Classes="muted"
                               Text="Parameters are optional, but each one needs key, name, and defaultValue." TextWrapping="Wrap" />
                    <TextBox x:Name="PluginInfoExampleTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             Classes="code-editor"
                             MinHeight="260" />
                </StackPanel>
            </Border>

            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="section-title"
                               Text="Plugin JSON Operations" />
                    <TextBlock Text="Each plugin JSON file can be either a single object or an array of objects." TextWrapping="Wrap" />
                    <TextBlock Classes="muted"
                               Text="All .txt files in the base excel folder are supported except itemstatcost.txt. Most files match rows by a unique column (e.g. Skill for skills.txt, Id for monstats.txt). Files whose identifier column contains duplicates use a numeric row ID (0-based data row index) instead (e.g. magicprefix.txt, cubemain.txt, hireling.txt)." TextWrapping="Wrap" />
                    <TextBlock Classes="muted"
                               Text="String JSON files under data/local/lng/strings (e.g. item-runes.json) use a flat d2rr-style layout. Each entry lists 'file', the entry 'Key', and one or more language fields (enUS, zhTW, deDE, esES, frFR, itIT, koKR, plPL, esMX, jaJP, ptBR, ruRU, zhCN). Only the language fields present on that entry are replaced; all other languages on the matched D2R entry, and every other entry in the file, are left untouched. Fields that are not one of the recognized language codes are ignored." TextWrapping="Wrap" />
                    <TextBox x:Name="OperationsExampleTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             Classes="code-editor"
                             MinHeight="360" />
                </StackPanel>
            </Border>

            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Classes="section-title"
                               Text="Available Fields" />
                    <TextBlock Text="file: Required. Any .txt file from the base excel folder except itemstatcost.txt, or any .json file under data/local/lng/strings." TextWrapping="Wrap" />
                    <TextBlock Text="Excel (.txt) targets: rowIdentifier is required (value from the identifier column, or numeric row ID for files with duplicate identifiers); column is required (a column name on the target file); updatedValue is the replacement value, the multiplier when operation is multiplyExisting, or the text appended when operation is append; operation is optional (empty/replace, multiplyExisting, or append); parameterKey is optional (references a parameter in plugininfo.json)." TextWrapping="Wrap" />
                    <TextBlock Text="rowIdentifier also accepts a numeric index range in the form &quot;start-end&quot; (inclusive, 0-based) to apply one operation across many rows at once — e.g. &quot;50-100&quot; for automap.txt or &quot;300-400&quot; for skills.txt. Ranges bypass the identifier column and target rows purely by data row index, so they work on every supported .txt file." TextWrapping="Wrap" />
                    <TextBlock Text="append wraps the existing value in parentheses and concatenates your entry, e.g. (existingValue)+10*20." TextWrapping="Wrap" />
                    <TextBlock Text="Strings (.json) targets: Key is required and matches the D2R entry's Key. Alongside Key, add any of the 13 language fields (enUS, zhTW, deDE, esES, frFR, itIT, koKR, plPL, esMX, jaJP, ptBR, ruRU, zhCN) with the replacement string — only the listed language fields on the matched entry are overwritten." TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Classes="section-title"
                               Text="Parameter Tokens" />
                    <TextBlock Text="updatedValue also supports inline parameter tokens in the form {{parameter:key}}." TextWrapping="Wrap" />
                    <TextBlock Classes="muted"
                               Text="Example: set updatedValue to {{parameter:damageMultiplier}} if you want the value resolved from plugininfo.json at runtime." TextWrapping="Wrap" />
                    <TextBlock Classes="muted"
                               Text="Parameter tokens are not resolved inside string JSON language values — provide the final replacement text directly on those entries." TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Classes="section-title"
                               Text="Validation Rules" />
                    <TextBlock Text="The launcher rejects plugin file paths that are absolute or that traverse outside the plugin folder." TextWrapping="Wrap" />
                    <TextBlock Text="plugininfo.json must list files that actually exist in the archive." TextWrapping="Wrap" />
                    <TextBlock Text="modVersion is required and must be in #.#.# format (e.g. 3.0.7) or the plugin will be rejected." TextWrapping="Wrap" />
                    <TextBlock Text="multiplyExisting only works on numeric columns and requires either parameterKey or updatedValue." TextWrapping="Wrap" />
                    <TextBlock Text="append requires either parameterKey or updatedValue and works on any column type." TextWrapping="Wrap" />
                    <TextBlock Text="Unknown parameters and unknown target columns are reported as plugin errors." TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Classes="section-title"
                               Text="Sharing on GitHub Discussions" />
                    <TextBlock Text="To share your plugin through the launcher's User Plugins page, create a post in the Plugins discussion category on GitHub. The launcher scrapes discussion posts and requires specific fields in the post body." TextWrapping="Wrap" />
                    <TextBlock Text="Title: Your Plugin Name — displayed as the plugin title in the launcher." TextWrapping="Wrap" />
                    <TextBlock Text="Desc: or Description: A short summary — displayed under the title." TextWrapping="Wrap" />
                    <TextBlock Text="Mod: or ModVer: or ModVersion: followed by a version in #.#.# format — displayed next to the title. Posts without a valid mod version are not loaded." TextWrapping="Wrap" />
                    <TextBlock Text="Attach a .zip file to the post containing your plugin. Posts without a .zip attachment are not loaded." TextWrapping="Wrap" />
                    <TextBlock Classes="muted"
                               Text="The .zip must still contain a valid plugininfo.json with all required fields (name, version, modVersion, files). The launcher validates the archive on install." TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Classes="section-title"
                               Text="Current Limits" />
                    <TextBlock Text="All .txt files in the base excel folder are supported except itemstatcost.txt. Most files match rows by a unique column; files with duplicate identifier values use numeric row IDs." TextWrapping="Wrap" />
                    <TextBlock Text="replace, multiplyExisting, and append are the supported operations." TextWrapping="Wrap" />
                    <TextBlock Text="Most files use typed parsers from the D2RReimaginedTools library for column validation and data integrity." TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
