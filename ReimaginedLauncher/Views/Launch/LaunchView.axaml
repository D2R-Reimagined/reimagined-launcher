<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ReimaginedLauncher.Views.Launch.LaunchView">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,Auto,Auto"
              RowSpacing="18">
            <Border Classes="hero-panel"
                    Padding="22">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="view-title"
                                   Text="Enter The Hunt" />
                        <TextBlock Classes="muted"
                                   Text="Point the launcher at your Diablo II: Resurrected install, verify the Reimagined files, and launch straight into the dark."
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Button x:Name="StartGameButton"
                            Classes="accent"
                            Content="Start Game"
                            Click="OnRunClick"
                            Width="160"
                            IsEnabled="False"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Classes="panel"
                    Padding="20">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="section-title"
                                   Text="Install Directory" />
                        <TextBlock Classes="muted"
                                   Text="Select the Diablo II: Resurrected folder that contains your local mod installation." />
                    </StackPanel>

                    <Border x:Name="ValidationBanner"
                            Grid.Row="1"
                            Classes="warning-banner"
                            Padding="12"
                            IsVisible="False">
                        <TextBlock x:Name="ValidationBannerText"
                                   Foreground="{StaticResource GoldTextBrush}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <TextBox x:Name="DirectoryTextBox"
                                 IsReadOnly="True" />
                        <Button Grid.Column="1"
                                Content="Browse"
                                Click="OnInstallDirectoryClick"
                                VerticalContentAlignment="Center" />
                    </Grid>
                </Grid>
            </Border>

            <Border Classes="panel"
                    Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="section-title"
                               Text="Launch Command" />
                    <TextBlock Classes="muted"
                               Text="The exact command the launcher will send to the game process." />
                    <Border Background="#110A0A"
                            BorderBrush="#341516"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14">
                        <TextBlock x:Name="LaunchCommandText"
                                   TextWrapping="Wrap"
                                   FontFamily="Cascadia Code,Consolas,Monaco,monospace" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
