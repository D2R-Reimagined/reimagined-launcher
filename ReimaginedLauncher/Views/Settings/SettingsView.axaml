<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ReimaginedLauncher.Views.Settings.SettingsView">
    <StackPanel Spacing="16">
        <TextBlock Text="Backup Directory" Margin="0,0,0,8"/>
        <DockPanel>
            <TextBox x:Name="BackupTextBox" Width="500" IsReadOnly="True" Margin="0,0,8,0"/>
            <Button Content="Browse" Click="OnBackupDirectoryClick"/>
        </DockPanel>
        <TextBlock Text="Launch Parameters" Margin="0,8,0,0"/>
        <CheckBox x:Name="DirectLaunchCheckBox"
                  Content="-direct"
                  Checked="OnLaunchSettingChanged"
                  Unchecked="OnLaunchSettingChanged"/>
        <CheckBox x:Name="NoSoundCheckBox"
                  Content="-nosound"
                  Checked="OnLaunchSettingChanged"
                  Unchecked="OnLaunchSettingChanged"/>
        <CheckBox x:Name="SkipLogoVideoCheckBox"
                  Content="-skiplogovideo (may not work)"
                  Checked="OnLaunchSettingChanged"
                  Unchecked="OnLaunchSettingChanged"/>
        <CheckBox x:Name="NoRumbleCheckBox"
                  Content="-norumble"
                  Checked="OnLaunchSettingChanged"
                  Unchecked="OnLaunchSettingChanged"/>
        <CheckBox x:Name="ResetOfflineMapsCheckBox"
                  Content="-resetofflinemaps"
                  Checked="OnLaunchSettingChanged"
                  Unchecked="OnLaunchSettingChanged"/>
        <CheckBox x:Name="EnableRespecCheckBox"
                  Content="-enablerespec"
                  Checked="OnLaunchSettingChanged"
                  Unchecked="OnLaunchSettingChanged"/>
        <StackPanel Spacing="8">
            <TextBlock Text="-players"/>
            <ComboBox x:Name="PlayersComboBox"
                      Width="160"
                      SelectionChanged="OnPlayersSelectionChanged">
                <ComboBoxItem Content="Disabled"/>
                <ComboBoxItem Content="2"/>
                <ComboBoxItem Content="3"/>
                <ComboBoxItem Content="4"/>
                <ComboBoxItem Content="5"/>
                <ComboBoxItem Content="6"/>
                <ComboBoxItem Content="7"/>
                <ComboBoxItem Content="8"/>
            </ComboBox>
        </StackPanel>
    </StackPanel>
</UserControl>
