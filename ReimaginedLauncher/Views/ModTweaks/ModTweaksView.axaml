<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="520"
             x:Class="ReimaginedLauncher.Views.ModTweaks.ModTweaksView">
    <Grid RowDefinitions="Auto,*"
          RowSpacing="16">
        <ScrollViewer x:Name="RootScrollViewer"
                      Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalAlignment="Stretch"
                      Focusable="True"
                      PointerPressed="OnBackgroundPointerPressed">
            <StackPanel Spacing="16"
                        HorizontalAlignment="Stretch">
                <DockPanel>
                    <Button Content="Reset Tweaks"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"
                            Click="OnResetTweaksClick"/>
                    <StackPanel Spacing="4">
                        <TextBlock Classes="view-title" Text="Mod Tweaks"/>
                        <TextBlock Classes="muted"
                                   TextWrapping="Wrap"
                                   Text="Customize visuals, sounds, and gameplay for your selected installation. These are installed on game launch and will remain even if another launch method is used. Disable and launch game to remove."/>
                    </StackPanel>
                </DockPanel>

                <Border Classes="panel"
                        Padding="20"
                        HorizontalAlignment="Stretch">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="section-title"
                                       Text="Character Tweaks"/>
                            <TextBlock Classes="muted"
                                       Text="Adjust level-up progression values applied through charstats and skills."/>
                        </StackPanel>

                        <WrapPanel Orientation="Horizontal"
                                   ItemSpacing="16"
                                   LineSpacing="16">
                            <StackPanel Width="220"
                                        Spacing="8">
                                <TextBlock Text="Skill Points Per Level"
                                           FontWeight="SemiBold"/>
                                <ComboBox x:Name="SkillPointsComboBox"
                                          Width="180"
                                          HorizontalAlignment="Left"
                                          SelectionChanged="OnTweaksSelectionChanged">
                                    <ComboBoxItem Content="1 (Default)"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="5"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Width="220"
                                        Spacing="8">
                                <TextBlock Text="Attributes Per Level"
                                           FontWeight="SemiBold"/>
                                <ComboBox x:Name="AttributesComboBox"
                                          Width="180"
                                          HorizontalAlignment="Left"
                                          SelectionChanged="OnTweaksSelectionChanged">
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="5 (Default)"/>
                                    <ComboBoxItem Content="6"/>
                                    <ComboBoxItem Content="7"/>
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="9"/>
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="11"/>
                                    <ComboBoxItem Content="12"/>
                                    <ComboBoxItem Content="13"/>
                                    <ComboBoxItem Content="14"/>
                                    <ComboBoxItem Content="15"/>
                                    <ComboBoxItem Content="16"/>
                                    <ComboBoxItem Content="17"/>
                                    <ComboBoxItem Content="18"/>
                                    <ComboBoxItem Content="19"/>
                                    <ComboBoxItem Content="20"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Width="220"
                                        Spacing="8">
                                <TextBlock Text="Max Skill Level"
                                           FontWeight="SemiBold"/>
                                <ComboBox x:Name="MaxSkillLevelComboBox"
                                          Width="180"
                                          HorizontalAlignment="Left"
                                          SelectionChanged="OnTweaksSelectionChanged">
                                    <ComboBoxItem Content="5"/>
                                    <ComboBoxItem Content="6"/>
                                    <ComboBoxItem Content="7"/>
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="9"/>
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="11"/>
                                    <ComboBoxItem Content="12"/>
                                    <ComboBoxItem Content="13"/>
                                    <ComboBoxItem Content="14"/>
                                    <ComboBoxItem Content="15"/>
                                    <ComboBoxItem Content="16"/>
                                    <ComboBoxItem Content="17"/>
                                    <ComboBoxItem Content="18"/>
                                    <ComboBoxItem Content="19"/>
                                    <ComboBoxItem Content="20"/>
                                    <ComboBoxItem Content="21"/>
                                    <ComboBoxItem Content="22"/>
                                    <ComboBoxItem Content="23"/>
                                    <ComboBoxItem Content="24"/>
                                    <ComboBoxItem Content="25 (Default)"/>
                                </ComboBox>
                            </StackPanel>
                        </WrapPanel>
                </StackPanel>
            </Border>

                <Border Classes="panel"
                        Padding="20"
                        HorizontalAlignment="Stretch">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="section-title"
                                       Text="Difficulty Tweaks"/>
                            <TextBlock Classes="muted"
                                       Text="Override the ResistPenalty values in DifficultyLevels for each difficulty."/>
                        </StackPanel>

                    <WrapPanel Orientation="Horizontal"
                               ItemSpacing="16"
                               LineSpacing="16">
                        <StackPanel Width="220"
                                    Spacing="8">
                            <TextBlock Text="Normal Resist Penalty"
                                       FontWeight="SemiBold"/>
                            <TextBox x:Name="NormalResistPenaltyTextBox"
                                     Width="180"
                                     HorizontalAlignment="Left"
                                     LostFocus="OnResistPenaltyChanged"
                                     KeyDown="OnResistPenaltyKeyDown"/>
                            <TextBlock Classes="muted"
                                       Text="Default: 0"/>
                        </StackPanel>

                        <StackPanel Width="220"
                                    Spacing="8">
                            <TextBlock Text="Nightmare Resist Penalty"
                                       FontWeight="SemiBold"/>
                            <TextBox x:Name="NightmareResistPenaltyTextBox"
                                     Width="180"
                                     HorizontalAlignment="Left"
                                     LostFocus="OnResistPenaltyChanged"
                                     KeyDown="OnResistPenaltyKeyDown"/>
                            <TextBlock Classes="muted"
                                       Text="Default: -60"/>
                        </StackPanel>

                        <StackPanel Width="220"
                                    Spacing="8">
                            <TextBlock Text="Hell Resist Penalty"
                                       FontWeight="SemiBold"/>
                            <TextBox x:Name="HellResistPenaltyTextBox"
                                     Width="180"
                                     HorizontalAlignment="Left"
                                     LostFocus="OnResistPenaltyChanged"
                                     KeyDown="OnResistPenaltyKeyDown"/>
                            <TextBlock Classes="muted"
                                       Text="Default: -120"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

                <Border Classes="panel"
                        Padding="20"
                        HorizontalAlignment="Stretch">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="section-title"
                                       Text="Sound Tweaks"/>
                            <TextBlock Classes="muted"
                                       Text="Optional local audio changes applied to excel data before launch."/>
                        </StackPanel>

                    <StackPanel Spacing="4">
                        <CheckBox x:Name="RemovePaladinAuraSoundCheckBox"
                                  Content="Remove Paladin Aura Sound"
                                  IsCheckedChanged="OnSoundTweaksChanged"/>
                        <TextBlock Classes="muted"
                                   Margin="28,0,0,0"
                                   Text="Stops Paladin aura sounds from constantly turning on and off. Useful if you teleport with a mercenary using aura-on-equip gear."/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <CheckBox x:Name="RestoreTerrorZoneFanfareCheckBox"
                                  Content="Restore Terror Zone Fanfare"
                                  IsCheckedChanged="OnSoundTweaksChanged"/>
                        <TextBlock Classes="muted"
                                   Margin="28,0,0,0"
                                   Text="Restores the sound that plays the first time you enter a terrorized zone from a non-terrorized zone."/>
                    </StackPanel>
                </StackPanel>
            </Border>

                <Border Classes="panel"
                        Padding="20"
                        HorizontalAlignment="Stretch">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="section-title"
                                       Text="Visual Tweaks"/>
                            <TextBlock Classes="muted"
                                       Text="Optional local visual changes applied to hd JSON data before launch."/>
                        </StackPanel>

                    <StackPanel Spacing="4">
                        <CheckBox x:Name="RemoveSplashVfxCheckBox"
                                  Content="Remove Splash VFX"
                                  IsCheckedChanged="OnVisualTweaksChanged"/>
                        <TextBlock Classes="muted"
                                   Margin="28,0,0,0"
                                   Text="Removes the red dust cloud effect from the Splash Charm. The charm still works the same way."/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <CheckBox x:Name="MakeTooltipBackgroundOpaqueCheckBox"
                                  Content="Make Tooltip Background Opaque (HDR Tooltip Fix)"
                                  IsCheckedChanged="OnVisualTweaksChanged"/>
                        <TextBlock Classes="muted"
                                   Margin="28,0,0,0"
                                   Text="Makes item tooltip backgrounds solid black so they stay readable with HDR on."/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <CheckBox x:Name="RemoveHelmetVisualCheckBox"
                                  Content="Remove Helmet Visual"
                                  IsCheckedChanged="OnVisualTweaksChanged"/>
                        <TextBlock Classes="muted"
                                   Margin="28,0,0,0"
                                   Text="Creates blank helmet and circlet hd JSON overrides so equipped headgear stays hidden visually."/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <CheckBox x:Name="TerrorZonePurpleOverlayCheckBox"
                                  Content="Restore Terror Zone Overlay"
                                  IsCheckedChanged="OnVisualTweaksChanged"/>
                        <TextBlock Classes="muted"
                                   Margin="28,0,0,0"
                                   Text="Restores the purple screen overlay in terrorized areas."/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <CheckBox x:Name="RemoveVignetteCheckBox"
                                  Content="Remove Vignette"
                                  IsCheckedChanged="OnVisualTweaksChanged"/>
                        <TextBlock Classes="muted"
                                   Margin="28,0,0,0"
                                   Text="Removes the blurry black borders from the edge of the screen. Works with widescreen but does not remove engine-set black bars."/>
                    </StackPanel>
                </StackPanel>
            </Border>

                <Border Classes="panel"
                        Padding="20"
                        HorizontalAlignment="Stretch">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="section-title"
                                       Text="Gameplay Tweaks"/>
                            <TextBlock Classes="muted"
                                       Text="Optional local tweaks that directly affect gameplay"/>
                        </StackPanel>

                    <StackPanel Spacing="4">
                        <CheckBox x:Name="TerrorizeAllZonesCheckBox"
                                  Content="Terrorize All Zones"
                                  IsCheckedChanged="OnZoneTweaksChanged"/>
                        <TextBlock Classes="muted"
                                   Margin="28,0,0,0"
                                   Text="Terrorize the entire game at one time, hourly warnings still apear but do nothing. You can save and exit to change the unique monster modifier."/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Orb &amp; Rune Stack Drops"
                                   FontWeight="SemiBold"/>
                        <TextBlock Classes="muted"
                                   Margin="28,0,0,0"
                                   Text="Make a selection to determine how Power Orbs and Runes will drop."/>
                    </StackPanel>

                    <WrapPanel Orientation="Horizontal"
                               Margin="28,0,0,0"
                               ItemSpacing="16"
                               LineSpacing="16">
                        <StackPanel Width="220"
                                    Spacing="8">
                            <TextBlock Text="Orbs"
                                       FontWeight="SemiBold"/>
                            <ComboBox x:Name="OrbStackDropsComboBox"
                                      Width="180"
                                      HorizontalAlignment="Left"
                                      SelectionChanged="OnStackDropsChanged">
                                <ComboBoxItem Content="Default"/>
                                <ComboBoxItem Content="Unstacked"/>
                                <ComboBoxItem Content="Stacked"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Width="220"
                                    Spacing="8">
                            <TextBlock Text="Runes"
                                       FontWeight="SemiBold"/>
                            <ComboBox x:Name="RuneStackDropsComboBox"
                                      Width="180"
                                      HorizontalAlignment="Left"
                                      SelectionChanged="OnStackDropsChanged">
                                <ComboBoxItem Content="Default"/>
                                <ComboBoxItem Content="Unstacked"/>
                                <ComboBoxItem Content="Stacked"/>
                            </ComboBox>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>
            </StackPanel>
        </ScrollViewer>

        <Border x:Name="WarningBorder"
                Grid.Row="0"
                Classes="warning-banner"
                IsVisible="False"
                Padding="12">
            <TextBlock x:Name="WarningTextBlock"
                       Foreground="{StaticResource GoldTextBrush}"
                       TextWrapping="Wrap"
                       Text="The selected tweaks alter the balance for Reimagined and the gameplay will be easier/harder than intended. We balance based on the default values only."/>
        </Border>
    </Grid>
</UserControl>
