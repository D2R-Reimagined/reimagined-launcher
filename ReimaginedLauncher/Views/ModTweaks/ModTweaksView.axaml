<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="520"
             x:Class="ReimaginedLauncher.Views.ModTweaks.ModTweaksView">
    <Grid RowDefinitions="*,Auto"
          RowSpacing="16">
        <ScrollViewer x:Name="RootScrollViewer"
                      Grid.Row="0"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Focusable="True"
                      PointerPressed="OnBackgroundPointerPressed">
            <StackPanel Spacing="16">
                <StackPanel Spacing="4">
                    <TextBlock Classes="view-title" Text="Mod Tweaks"/>
                    <TextBlock Classes="muted" Text="Customize gameplay and visual tweaks for your local launcher configuration."/>
                </StackPanel>

                <Border Classes="panel"
                        Padding="20">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="section-title"
                                       Text="Character Tweaks"/>
                            <TextBlock Classes="muted"
                                       Text="Adjust level-up progression values applied through charstats and skills."/>
                        </StackPanel>

                        <Grid ColumnDefinitions="220,220,180,*" ColumnSpacing="16" RowDefinitions="Auto">
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="Skill Points Per Level"
                                           FontWeight="SemiBold"/>
                                <ComboBox x:Name="SkillPointsComboBox"
                                          Width="180"
                                          HorizontalAlignment="Left"
                                          SelectionChanged="OnTweaksSelectionChanged">
                                    <ComboBoxItem Content="1 (Default)"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="5"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="Attributes Per Level"
                                           FontWeight="SemiBold"/>
                                <ComboBox x:Name="AttributesComboBox"
                                          Width="180"
                                          HorizontalAlignment="Left"
                                          SelectionChanged="OnTweaksSelectionChanged">
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="2"/>
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="5 (Default)"/>
                                    <ComboBoxItem Content="6"/>
                                    <ComboBoxItem Content="7"/>
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="9"/>
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="11"/>
                                    <ComboBoxItem Content="12"/>
                                    <ComboBoxItem Content="13"/>
                                    <ComboBoxItem Content="14"/>
                                    <ComboBoxItem Content="15"/>
                                    <ComboBoxItem Content="16"/>
                                    <ComboBoxItem Content="17"/>
                                    <ComboBoxItem Content="18"/>
                                    <ComboBoxItem Content="19"/>
                                    <ComboBoxItem Content="20"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="8">
                                <TextBlock Text="Max Skill Level"
                                           FontWeight="SemiBold"/>
                                <TextBox x:Name="MaxSkillLevelTextBox"
                                         Width="180"
                                         HorizontalAlignment="Left"
                                         LostFocus="OnMaxSkillLevelChanged"
                                         KeyDown="OnMaxSkillLevelKeyDown"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Classes="panel"
                        Padding="20">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="section-title"
                                       Text="Difficulty Tweaks"/>
                            <TextBlock Classes="muted"
                                       Text="Override the ResistPenalty values in DifficultyLevels for each difficulty."/>
                        </StackPanel>

                        <Grid ColumnDefinitions="220,220,220,*" ColumnSpacing="16" RowDefinitions="Auto">
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="Normal Resist Penalty"
                                           FontWeight="SemiBold"/>
                                <TextBox x:Name="NormalResistPenaltyTextBox"
                                         Width="180"
                                         HorizontalAlignment="Left"
                                         LostFocus="OnResistPenaltyChanged"
                                         KeyDown="OnResistPenaltyKeyDown"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="Nightmare Resist Penalty"
                                           FontWeight="SemiBold"/>
                                <TextBox x:Name="NightmareResistPenaltyTextBox"
                                         Width="180"
                                         HorizontalAlignment="Left"
                                         LostFocus="OnResistPenaltyChanged"
                                         KeyDown="OnResistPenaltyKeyDown"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="8">
                                <TextBlock Text="Hell Resist Penalty"
                                           FontWeight="SemiBold"/>
                                <TextBox x:Name="HellResistPenaltyTextBox"
                                         Width="180"
                                         HorizontalAlignment="Left"
                                         LostFocus="OnResistPenaltyChanged"
                                         KeyDown="OnResistPenaltyKeyDown"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Classes="panel"
                        Padding="20">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="section-title"
                                       Text="Sound Tweaks"/>
                            <TextBlock Classes="muted"
                                       Text="Optional local audio changes applied to excel data before launch."/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <CheckBox x:Name="RemovePaladinAuraSoundCheckBox"
                                      Content="Remove Paladin Aura Sound"
                                      Checked="OnSoundTweaksChanged"
                                      Unchecked="OnSoundTweaksChanged"/>
                            <TextBlock Classes="muted"
                                       Margin="28,0,0,0"
                                       Text="Blanks onsound for paladin_aura_* rows in states.txt for both excel variants."/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Classes="panel"
                        Padding="20">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="section-title"
                                       Text="Visual Tweaks"/>
                            <TextBlock Classes="muted"
                                       Text="Optional local visual changes applied to hd JSON data before launch."/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <CheckBox x:Name="RemoveSplashVfxCheckBox"
                                      Content="Remove Splash VFX"
                                      Checked="OnVisualTweaksChanged"
                                      Unchecked="OnVisualTweaksChanged"/>
                            <TextBlock Classes="muted"
                                       Margin="28,0,0,0"
                                       Text="Blanks proc_splash_explode in missiles.json to remove the splash visual effect."/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border x:Name="WarningBorder"
                Grid.Row="1"
                Classes="warning-banner"
                IsVisible="False"
                Padding="12">
            <TextBlock x:Name="WarningTextBlock"
                       Foreground="{StaticResource GoldTextBrush}"
                       TextWrapping="Wrap"
                       Text="This is the unintended Reimagined experience. Defaults are 1 skill point, 5 attributes per level, max skill level 25, default difficulty resist penalties of 0, -60, and -120, with Remove Paladin Aura Sound and Remove Splash VFX turned off."/>
        </Border>
    </Grid>
</UserControl>
