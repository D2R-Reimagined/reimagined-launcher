<Window 
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:controls="clr-namespace:Avalonia.Notification.Controls;assembly=Notification.Avalonia"
    xmlns:reimaginedLauncher1="clr-namespace:ReimaginedLauncher.Utilities.ViewModels"
    xmlns:local="clr-namespace:ReimaginedLauncher"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
    x:Class="ReimaginedLauncher.MainWindow"
    x:DataType="reimaginedLauncher1:NexusUserViewModel"
    Title="D2R Reimagined Launcher"
    MinWidth="1180"
    MinHeight="760"
>
    <Window.Styles>
        <materialIcons:MaterialIconStyles />
    </Window.Styles>
    <Grid ColumnDefinitions="300,*" Margin="20" ColumnSpacing="18">
        <Border Grid.Column="0"
                Classes="panel"
                Padding="20">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="18">
                <StackPanel Spacing="18">
                    <Border Classes="hero-panel"
                            Padding="16">
                        <Grid RowDefinitions="Auto,Auto"
                              ColumnDefinitions="*,Auto"
                              RowSpacing="10"
                              ColumnSpacing="12">
                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="2"
                                       Text="D2R Reimagined"
                                       FontFamily="Georgia"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource GoldTextBrush}" />

                            <StackPanel Grid.Row="1"
                                        Grid.Column="0"
                                        Spacing="4"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Launcher"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource GoldBrush}" />
                                <TextBlock Classes="muted"
                                           Text="A darker control surface for launching, updating, and safeguarding your install."
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    Width="72"
                                    Height="72"
                                    Background="#120809"
                                    BorderBrush="#7B2326"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="8"
                                    HorizontalAlignment="Right">
                                <Image x:Name="LogoImage"
                                       Stretch="Uniform" />
                            </Border>
                        </Grid>
                    </Border>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Navigation"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource GoldBrush}" />
                        <ListBox x:Name="NavigationList"
                                 Classes="nav-list"
                                 SelectionChanged="OnNavigationSelectionChanged">
                            <ListBoxItem x:Name="LaunchNavItem" Content="Launch" />
                            <ListBoxItem Content="Plugins" />
                            <ListBoxItem Content="Backups" />
                            <ListBoxItem Content="Settings" />
                            <ListBoxItem Content="Mod Tweaks" />
                            <ListBoxItem x:Name="UpdateNavItem" Content="Update" />
                        </ListBox>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Spacing="10">
                    <TextBlock x:Name="LauncherVersionTextBlock"
                               Classes="muted"
                               HorizontalAlignment="Center" />
                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="*,*"
                          ColumnSpacing="8"
                          RowSpacing="8">
                        <Button Grid.Row="0"
                                Grid.Column="0"
                                Classes="link-button"
                                Content="{materialIcons:MaterialIconTextExt Text=Website, Kind=OpenInNew, IconPlacement=Right}"
                                Name="WebsiteButton"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Click="OnVisitWebsiteClicked" />
                        <Button Grid.Row="0"
                                Grid.Column="1"
                                Classes="link-button"
                                Content="{materialIcons:MaterialIconTextExt Text=Wiki, Kind=OpenInNew, IconPlacement=Right}"
                                Name="WikiButton"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Click="OnVisitWebsiteClicked" />
                        <Button Grid.Row="1"
                                Grid.Column="0"
                                Classes="link-button"
                                Content="{materialIcons:MaterialIconTextExt Text=Nexus, Kind=OpenInNew, IconPlacement=Right}"
                                Name="NexusButton"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Click="OnVisitWebsiteClicked" />
                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Classes="link-button"
                                Content="{materialIcons:MaterialIconTextExt Text=Discord, Kind=OpenInNew, IconPlacement=Right}"
                                Name="DiscordButton"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Click="OnVisitWebsiteClicked" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="18">
            <Border Grid.Row="0"
                    Classes="panel"
                    Padding="20,16">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="16">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Sanctum Status"
                                   Foreground="{StaticResource GoldBrush}"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="VersionTextBlock"
                                   FontFamily="Georgia"
                                   FontSize="24"
                                   FontWeight="Bold" />
                        <TextBlock Classes="muted"
                                   Text="Use the launcher to keep your install current, backed up, and ready to descend." />
                    </StackPanel>

                    <Grid Grid.Column="1"
                          VerticalAlignment="Center">
                        <Button Classes="accent"
                                Content="Login with Nexus Mods"
                                Click="OnNexusLoginClicked"
                                IsVisible="{Binding IsLoggedIn, Converter={StaticResource InverseBooleanConverter}}"
                                VerticalAlignment="Center" />
                        <Button x:Name="UserMenuButton"
                                Classes="accent"
                                Content="{Binding Name}"
                                Click="OnUserMenuClick"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                IsVisible="{Binding IsLoggedIn}">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Logout" Click="OnLogoutClicked"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Classes="panel"
                    Padding="24">
                <ContentControl x:Name="ContentArea" />
            </Border>
        </Grid>

        <controls:NotificationMessageContainer Grid.Column="1"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               Manager="{x:Static local:MainWindow.ManagerInstance}" />
    </Grid>
    
</Window>
