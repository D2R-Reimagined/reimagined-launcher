<Window 
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:controls="clr-namespace:Avalonia.Notification.Controls;assembly=Notification.Avalonia"
    xmlns:reimaginedLauncher1="clr-namespace:ReimaginedLauncher.Utilities.ViewModels"
    xmlns:local="clr-namespace:ReimaginedLauncher"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
    x:Class="ReimaginedLauncher.MainWindow"
    x:DataType="reimaginedLauncher1:NexusUserViewModel"
    Title="D2R Reimagined Launcher"
>
    <Window.Styles>
        <materialIcons:MaterialIconStyles />
    </Window.Styles>
    <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,*">
        <Grid Grid.RowSpan="2" Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ListBox x:Name="NavigationList"
                     SelectionChanged="OnNavigationSelectionChanged"
                     Grid.Row="0"
                     Margin="10">
                <ListBoxItem x:Name="LaunchNavItem" Content="Launch" />
                <ListBoxItem Content="Backups" />
                <ListBoxItem Content="Settings" />
                <ListBoxItem Content="Mod Tweaks" />
                <ListBoxItem x:Name="UpdateNavItem" Content="Update" />
            </ListBox>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,0,10,10" Spacing="5">
                <Button Content="{materialIcons:MaterialIconTextExt Text=Website, Kind=OpenInNew, IconPlacement=Right}"
                        Name="WebsiteButton"
                        HorizontalAlignment="Left"
                        Click="OnVisitWebsiteClicked"/>
                <Button Content="{materialIcons:MaterialIconTextExt Text=Wiki, Kind=OpenInNew, IconPlacement=Right}"
                        Name="WikiButton"
                        HorizontalAlignment="Left"
                        Click="OnVisitWebsiteClicked"/>
                <Button Content="{materialIcons:MaterialIconTextExt Text=Nexus, Kind=OpenInNew, IconPlacement=Right}"
                        Name="NexusButton"
                        HorizontalAlignment="Left"
                        Click="OnVisitWebsiteClicked"/>
                <Button Content="{materialIcons:MaterialIconTextExt Text=Discord, Kind=OpenInNew, IconPlacement=Right}"
                        Name="DiscordButton"
                        HorizontalAlignment="Left"
                        Click="OnVisitWebsiteClicked"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="0" Grid.Column="1" Margin="10,0,10,8" Height="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="VersionTextBlock"
                       Grid.Column="0"
                       Margin="0,5,0,0"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Grid Grid.Column="2" Margin="0,0,10,0" VerticalAlignment="Center">
                <Button Content="Login with Nexus Mods"
                        Click="OnNexusLoginClicked"
                        IsVisible="{Binding IsLoggedIn, Converter={StaticResource InverseBooleanConverter}}"
                        VerticalAlignment="Center"/>
                <Button x:Name="UserMenuButton"
                        Content="{Binding Name}"
                        Click="OnUserMenuClick"
                        VerticalAlignment="Center"
                        FontWeight="Bold"
                        IsVisible="{Binding IsLoggedIn}">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Logout" Click="OnLogoutClicked"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </Grid>
        </Grid>

        <Border Grid.Row="1" Grid.Column="1" Padding="10,24,24,24" CornerRadius="8">
            <ContentControl x:Name="ContentArea" />
        </Border>

        <controls:NotificationMessageContainer Grid.RowSpan="2"
                                               Grid.Column="1"
                                               Margin="10,10,10,10"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               Manager="{x:Static local:MainWindow.ManagerInstance}" />
    </Grid>
    
</Window>
